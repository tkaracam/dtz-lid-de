{
  "name": "dtz-lernplattform",
  "version": "1.0.0",
  "description": "DTZ Lernplattform - Deutsch-Test für Zuwanderer",
  "main": "index.html",
  "scripts": {
    "build": "echo 'No build step required for vanilla JS'",
    "sync": "cap sync",
    "copy": "cap copy",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "run:ios": "cap run ios --livereload --external",
    "run:android": "cap run android --livereload --external",
    "build:ios": "cap copy ios && cd ios/App && xcodebuild -workspace App.xcworkspace -scheme App -configuration Release",
    "build:android": "cap copy android && cd android && ./gradlew assembleRelease"
  },
  "keywords": [
    "dtz",
    "german",
    "language-learning",
    "integration-course"
  ],
  "author": "DTZ Lernplattform",
  "license": "MIT",
  "dependencies": {
    "@capacitor/core": "^5.0.0",
    "@capacitor/ios": "^5.0.0",
    "@capacitor/android": "^5.0.0",
    "@capacitor/push-notifications": "^5.0.0",
    "@capacitor/local-notifications": "^5.0.0",
    "@capacitor/splash-screen": "^5.0.0",
    "@capacitor/status-bar": "^5.0.0",
    "@capacitor/storage": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0"
  }
}
