{
    "name": "dtz-lid/platform",
    "description": "DTZ-LiD Subscription Platform",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "firebase/php-jwt": "^6.10",
        "stripe/stripe-php": "^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.8",
        "phpstan/phpstan": "^1.10",
        "robmorgan/phinx": "^0.16"
    },
    "autoload": {
        "psr-4": {
            "DTZ\\": "src/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs --standard=PSR12 src/",
        "lint:fix": "phpcbf --standard=PSR12 src/",
        "analyse": "phpstan analyse src --level=5",
        "migrate": "phinx migrate -c phinx.php",
        "migrate:rollback": "phinx rollback -c phinx.php",
        "migrate:status": "phinx status -c phinx.php",
        "seed": "phinx seed:run -c phinx.php",
        "db:fresh": "php bin/dtz fresh",
        "db:reset": "php bin/dtz reset"
    }
}
