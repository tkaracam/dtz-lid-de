# DTZ Learning Platform - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Application Settings
# ============================================
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com

# ============================================
# Database Configuration
# ============================================
# Option 1: SQLite (default for single instance)
DB_DRIVER=sqlite
DB_PATH=/var/www/html/database/dtz_production.db

# Option 2: PostgreSQL (for production scale)
# DB_DRIVER=pgsql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=dtz_learning
# DB_USER=dtz_user
# DB_PASSWORD=your_secure_password

# ============================================
# Security
# ============================================
# Generate a strong JWT secret: openssl rand -base64 32
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars

# ============================================
# OpenAI Configuration (for AI writing feedback)
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# ============================================
# Azure Text-to-Speech
# ============================================
AZURE_TTS_KEY=your-azure-tts-key
AZURE_TTS_REGION=westeurope

# ============================================
# Stripe Payment Configuration
# ============================================
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_BASIC_PRICE_ID=price_basic_monthly
STRIPE_PREMIUM_PRICE_ID=price_premium_monthly
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_premium_yearly

# ============================================
# Email Configuration (for notifications)
# ============================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_FROM=noreply@your-domain.com
SMTP_FROM_NAME="DTZ Lernplattform"

# ============================================
# Redis (optional - for caching/sessions)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# Storage
# ============================================
# Local or S3/R2
STORAGE_DRIVER=local
STORAGE_PATH=/var/www/html/storage

# Cloudflare R2 (optional)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# ============================================
# Monitoring (optional)
# ============================================
SENTRY_DSN=
LOG_LEVEL=warning

# ============================================
# Development Only
# ============================================
# DEMO_MODE=true
