# Database Configuration
# SQLite (Development)
# DB_TYPE=sqlite
# DB_PATH=./database/dtz_lid.db

# PostgreSQL (Production)
DB_TYPE=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dtz_lid
DB_USER=dtz_user
DB_PASS=your_secure_password

# JWT Configuration
JWT_SECRET=your_very_secure_random_string_here_min_32_chars

# OpenAI Configuration
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4

# Azure Text-to-Speech
AZURE_TTS_KEY=your_azure_key
AZURE_TTS_REGION=westeurope
AZURE_TTS_ENDPOINT=https://westeurope.api.cognitive.microsoft.com/

# Stripe Configuration (Payments)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# AWS S3 / Cloudflare R2 (Audio Storage)
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=xxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxx
AWS_BUCKET=dtz-lid-audio
AWS_REGION=eu-central-1

# Redis (Queue & Cache)
REDIS_URL=redis://localhost:6379

# Application Settings
APP_ENV=production
APP_URL=https://dtz-lid.de
ADMIN_EMAIL=admin@dtz-lid.de

# Email (SendGrid/AWS SES)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_key
